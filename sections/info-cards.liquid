{% schema %}
{
  "name": "Why Fey Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Why Fey & Co."
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom desktop",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icono"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Card description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Fey Section",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}

<style>
.why-fey-{{ section.id }} {
  background: #272A4C;
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.why-fey-title-{{ section.id }} {
  font-weight: 400;
  font-size: 32px;
  line-height: 110%;
  margin-bottom: 50px;
  color: #fff;
}

.why-fey-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  max-width: 1200px;
}

.why-fey-card-{{ section.id }} {
  padding: 0 40px;
  position: relative;
}

.why-fey-card-{{ section.id }}:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 100%;
  width: 1px;
  background: #373A60;
}

.why-fey-icon-{{ section.id }} {
  width: 60px;
  height: 60px;
  margin: 0 auto 20px;
}

.why-fey-icon-{{ section.id }} img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.why-fey-card-title-{{ section.id }} {
  font-family: 'Minerva Modern';
  font-size: 18px;
  line-height: 110%;
  margin-bottom: 6px;
  color: #fff;
}

.why-fey-card-text-{{ section.id }} {
  font-family: "Jost", sans-serif;
  font-size: 14px;
  line-height: 150%;
  color: #BCBDC8;
  opacity: 0.85;
}

/* MOBILE */
@media (max-width: 768px) {
  .why-fey-grid-{{ section.id }} {
    max-width: 320px;
  }
  .why-fey-{{ section.id }} {
    padding: {{ section.settings.padding_top_mobile }}px 20px {{ section.settings.padding_bottom_mobile }}px;
  }

  .why-fey-title-{{ section.id }} {
    font-size: 24px;
    margin-bottom: 30px;
  }

  .why-fey-grid-{{ section.id }} {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .why-fey-card-{{ section.id }} {
    padding: 0;
  }

  .why-fey-card-{{ section.id }}::after {
    display: none;
  }
}
</style>

<section class="why-fey-{{ section.id }}">
  <h2 class="why-fey-title-{{ section.id }}">
    {{ section.settings.title }}
  </h2>

  <div class="why-fey-grid-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="why-fey-card-{{ section.id }}">
        
        {% if block.settings.icon %}
          <div class="why-fey-icon-{{ section.id }}">
            <img src="{{ block.settings.icon | image_url }}" alt="">
          </div>
        {% endif %}

        <div class="why-fey-card-title-{{ section.id }}">
          {{ block.settings.title }}
        </div>

        <div class="why-fey-card-text-{{ section.id }}">
          {{ block.settings.text }}
        </div>

      </div>
    {% endfor %}
  </div>
</section>