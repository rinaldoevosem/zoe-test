{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{{ 'custom-variants.css' | asset_url | stylesheet_tag }}

{% assign block_settings = block.settings %}

{% unless product_resource.has_only_default_variant %}

<variant-picker
  class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product_resource.id }}"
  data-block-id="{{ block.id }}"
  data-product-url="{{ product_resource.url }}"
  ref="mainVariantPicker"
  {{ block.shopify_attributes }}
>

  <form class="variant-picker__form">

    {%- for product_option in product_resource.options_with_values -%}
      {% assign option_name = product_option.name | downcase %}
      {% assign fieldset_index = forloop.index0 %}

      <!-- SIZE (dropdown custom) -->
      {% if option_name == 'size' %}
        <div class="variant-size-dropdown">
          <div class="variant-size-row">

            <div class="variant-size-label">
              Ring Size:
              <span class="variant-selected" data-option="{{ product_option.name }}">
                {{ product_option.selected_value }} EU
              </span>
             <span class="variant-info-icon">
                i
              </span>
            </div>

            <div class="variant-size-select-wrapper">
              <select
                name="options[{{ product_option.name }}]"
                class="size-select"
              >
                {% for product_option_value in product_option.values %}
                  <option
                    value="{{ product_option_value | escape }}"
                    data-option-value-id="{{ product_option_value.id }}"
                    data-variant-id="{{ product_option_value.variant.id }}"
                    {% if product_option_value.selected %}selected{% endif %}
                  >
                    {{ product_option_value }} EU
                  </option>
                {% endfor %}
              </select>
                <span class="select-arrow">
                     <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                         <path d="M1 1L5 5L9 1" stroke="#737373" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </span>
            </div>

          </div>
        </div>
        {% continue %}
      {% endif %}

      <!-- RADIO OPTIONS -->
      <fieldset
        class="custom-variant variant-{{ option_name }}"
        data-fieldset-index="{{ fieldset_index }}"
        ref="fieldsets[]"
      >

        <div class="variant-header">
          <span class="variant-title">
            {{ product_option.name }}:
            <span class="variant-selected" data-option="{{ product_option.name }}">
              {{ product_option.selected_value }}
            </span>
              <span class="variant-info-icon">
                i
              </span>
          </span>
        </div>

        <div class="variant-grid">

          {% for product_option_value in product_option.values %}
            <label class="variant-item">

              <input
                type="radio"
                name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                value="{{ product_option_value | escape }}"
                data-fieldset-index="{{ fieldset_index }}"
                data-input-index="{{ forloop.index0 }}"
                data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                data-option-value-id="{{ product_option_value.id }}"
                data-option-available="{{ product_option_value.available }}"
                data-connected-product-url="{{ product_option_value.product_url }}"
                data-variant-id="{{ product_option_value.variant.id }}"
                {% if product_option_value.selected %}
                  checked
                  data-current-checked="true"
                {% endif %}
              >

              {% if option_name == 'shape' %}
                {% assign img = product_option_value.variant.featured_media.preview_image %}
                {% if img %}
                  <img src="{{ img | image_url: width: 80 }}" alt="{{ product_option_value }}">
                {% endif %}

              {% elsif option_name == 'metal' %}
                  {% assign value_down = product_option_value | downcase %}

                  {% if value_down contains 'yellow' %}
                    {% assign metal_class = 'yellow-gold' %}
                  {% elsif value_down contains 'white' %}
                    {% assign metal_class = 'white-gold' %}
                  {% elsif value_down contains 'rose' %}
                    {% assign metal_class = 'rose-gold' %}
                  {% elsif value_down contains 'platinum' or value_down contains 'pt' %}
                    {% assign metal_class = 'platinum' %}
                  {% else %}
                    {% assign metal_class = '' %}
                  {% endif %}

                  <span class="color-swatch {{ metal_class }}">
                    <span class="metal-label">
                      {{ product_option_value | split: ' ' | first }}
                    </span>
                  </span>

              {% else %}
                <span class="text">
                  {{ product_option_value }}
                </span>
              {% endif %}

            </label>
          {% endfor %}

        </div>

      </fieldset>

    {% endfor %}

    <!-- 🔥 ESTO ES CLAVE PARA QUE FUNCIONE -->
    <script type="application/json">
      {{ product_resource.selected_or_first_available_variant | json }}
    </script>

  </form>

</variant-picker>

{% endunless %}

{% stylesheet %}
  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }
{% endstylesheet %}

<script>

document.addEventListener("mousedown", (e) => {
  const select = e.target.closest(".size-select");

  if (!select) return;

  const wrapper = select.closest(".variant-size-select-wrapper");
  const isOpen = wrapper.classList.contains("open");

  document.querySelectorAll(".variant-size-select-wrapper").forEach(w => {
    w.classList.remove("open");
  });

  if (!isOpen) {
    wrapper.classList.add("open");
  }
});

document.addEventListener("mousedown", (e) => {
  if (!e.target.closest(".variant-size-select-wrapper")) {
    document.querySelectorAll(".variant-size-select-wrapper").forEach(w => {
      w.classList.remove("open");
    });
  }
});

document.addEventListener("change", (e) => {
  if (e.target.type === "radio" || e.target.classList.contains("size-select")) {

    const form = e.target.closest("form");
    const formData = new FormData(form);

    const options = [];
    form.querySelectorAll("input[type='radio']:checked").forEach(input => {
      options.push(input.value);
    });

    const sizeSelect = form.querySelector(".size-select");
    if (sizeSelect) {
      options.push(sizeSelect.value);
    }

    const productData = JSON.parse(form.querySelector('[type="application/json"]').textContent);

  }
});

</script>